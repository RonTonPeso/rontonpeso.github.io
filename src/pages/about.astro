---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const aboutPhoto = `${basePath}delta_ronnie_wang_copy.jpg`;
---

<BaseLayout
	title="About | Ronnie Wang"
	description="About Ronald Ronnie Wang, a student in Penn Engineering interested in materials science, computer science, sustainability, and culture."
>
	<section class="page-section text-page">
		<p class="kicker">About the engineer</p>
		<h1 class="page-title">About</h1>
		<div class="about-layout">
			<div class="about-side">
				<figure class="about-photo">
					<img
						src={aboutPhoto}
						alt="Ronnie Wang sitting near large green plants by a window"
					/>
					<figcaption>Ronnie Wang</figcaption>
				</figure>
				<dl class="about-facts">
					<div>
						<dt>Studying</dt>
						<dd>Computer Science, BSE + Masters, Penn Engineering</dd>
					</div>
					<div>
						<dt>Research</dt>
						<dd>Li Group · material informatics with machine learning</dd>
					</div>
					<div>
						<dt>Building</dt>
						<dd>Penn Mobile · Android</dd>
					</div>
				</dl>
			</div>
			<div>
				<div class="prose">
					<p>
						Hello hello! I'm a student in the School of Engineering and
						Applied Science pursuing a major and masters degree in computer science.
						
					</p>
					<p>
						
					</p>
				</div>
				<div class="link-row" aria-label="Contact links">
					<a href="mailto:wronnie@seas.upenn.edu">Email</a>
					<a href="https://github.com/RonTonPeso">GitHub</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
