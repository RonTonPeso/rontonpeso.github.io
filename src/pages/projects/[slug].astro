---
import { projects, type Project } from "../../data/projects";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DemoRenderer from "../../components/DemoRenderer.astro";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project }
	}));
}

const { project } = Astro.props as { project: Project };
const basePath = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const projectsHref = `${basePath}projects`;
const slidesHref = project.slidesUrl ? `${basePath}${project.slidesUrl}` : undefined;
---

<BaseLayout title={`${project.title} | Ronnie Wang`} description={project.description}>
	<article class="page-section project-detail">
		<a class="back-link" href={projectsHref}>Back to projects</a>
		<header class="detail-header">
			<p class="kicker">Project field note</p>
			<h1 class="page-title">{project.title}</h1>
			<p class="blurb">{project.description}</p>
		</header>

		<DemoRenderer project={project} />

		<div class="detail-body">
			<div>
				<div class="prose">
					{project.details.map((paragraph) => <p>{paragraph}</p>)}
				</div>

				{
					project.embedUrl && (
						<iframe
							class="project-embed"
							src={project.embedUrl}
							title={`${project.title} embedded preview`}
							loading="lazy"
						/>
					)
				}
			</div>

			<aside class="detail-aside" aria-label={`${project.title} project metadata`}>
				<p>Stack and signals</p>
				<ul class="project-tags detail-tags" aria-label={`${project.title} technologies`}>
					{project.tags.map((tag) => <li>{tag}</li>)}
				</ul>

				{
					(project.repoUrl || project.demoUrl || slidesHref) && (
						<div class="link-row" aria-label={`${project.title} links`}>
							{project.repoUrl && (
								<a class="btn-primary link-btn" href={project.repoUrl}>
									<svg
										class="btn-icon"
										viewBox="0 0 16 16"
										fill="currentColor"
										aria-hidden="true"
									>
										<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
									</svg>
									Repository
								</a>
							)}
							{project.demoUrl && (
								<a class="btn-ghost link-btn" href={project.demoUrl}>
									Demo
								</a>
							)}
							{slidesHref && (
								<a class="btn-ghost link-btn" href={slidesHref} target="_blank" rel="noopener">
									Slides
								</a>
							)}
						</div>
					)
				}
			</aside>
		</div>
	</article>
</BaseLayout>
