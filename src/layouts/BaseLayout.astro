---
const {
	title = "Ronnie Wang",
	description = "Ronnie Wang is a software engineer passionate about AI and penguins."
} = Astro.props;

const pathname = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const hrefWithBase = (path: string) => `${basePath}${path.replace(/^\/+/, "")}`;
const currentPath = pathname.startsWith(basePath)
	? `/${pathname.slice(basePath.length)}`
	: pathname;
const penguinImage = hrefWithBase("penguin_profile.png");
const socialImage = new URL(penguinImage, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={socialImage} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />
		<link rel="icon" type="image/png" href={penguinImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800;9..144,900&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
		<style is:global>
			:root {
				--ink: #f5f7ec;
				--ink-muted: #b8c6c6;
				--ink-soft: #84989a;
				--night: #071019;
				--night-deep: #02060a;
				--night-veil: rgba(7, 16, 25, 0.74);
				--paper: #f4efe0;
				--paper-deep: #e7dfcc;
				--paper-ink: #182026;
				--paper-muted: #50605d;
				--line: rgba(191, 246, 228, 0.2);
				--line-strong: rgba(201, 255, 238, 0.42);
				--green: #70ff9e;
				--cyan: #61f2ff;
				--blue: #5489ff;
				--red: #ff5d6f;
				--violet: #b572ff;
				--gold: #ffe7a8;
				--shadow: 0 28px 90px rgba(0, 0, 0, 0.36);
				--page: 1120px;
				--radius: 8px;
				color: var(--ink);
				background: var(--night-deep);
				font-family: "IBM Plex Sans", "Helvetica Neue", sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			html {
				background: var(--night-deep);
				scroll-behavior: smooth;
			}

			body {
				position: relative;
				margin: 0;
				min-height: 100vh;
				overflow-x: hidden;
				/* deep polar night with ambient aurora skyglow bleeding from the top */
				background:
					radial-gradient(135% 70% at 50% -12%, rgba(112, 255, 158, 0.12), transparent 56%),
					radial-gradient(90% 60% at 82% -4%, rgba(181, 114, 255, 0.11), transparent 60%),
					radial-gradient(80% 55% at 18% 2%, rgba(97, 242, 255, 0.09), transparent 60%),
					linear-gradient(180deg, rgba(2, 6, 10, 0.22), var(--night-deep) 70%),
					linear-gradient(158deg, #04111c 0%, #061826 42%, #0d0a1e 100%);
				color: var(--ink);
			}

			/* aurora curtains: near-vertical rays that ripple and drift sideways */
			body::before {
				position: fixed;
				inset: -16vh -22vw auto -22vw;
				z-index: 0;
				height: 88vh;
				background:
					repeating-linear-gradient(
						95deg,
						transparent 0 2.4rem,
						rgba(112, 255, 158, 0.17) 3.3rem,
						rgba(97, 242, 255, 0.21) 4.6rem,
						transparent 6rem 8.5rem
					),
					repeating-linear-gradient(
						87deg,
						transparent 0 3.2rem,
						rgba(181, 114, 255, 0.14) 4.8rem,
						rgba(84, 137, 255, 0.16) 6.4rem,
						transparent 8rem 12.5rem
					);
				background-size: 220% 100%, 250% 100%;
				background-position: 0% 0%, 100% 0%;
				content: "";
				filter: blur(34px) saturate(165%);
				mask-image: linear-gradient(
					to bottom,
					rgba(0, 0, 0, 0.96) 0%,
					rgba(0, 0, 0, 0.55) 42%,
					transparent 82%
				);
				-webkit-mask-image: linear-gradient(
					to bottom,
					rgba(0, 0, 0, 0.96) 0%,
					rgba(0, 0, 0, 0.55) 42%,
					transparent 82%
				);
				opacity: 0.95;
				pointer-events: none;
				transform: skewX(-8deg);
				animation: aurora-drift 28s ease-in-out infinite alternate;
			}

			/* starfield: scattered points, densest near the top, gentle twinkle */
			body::after {
				position: fixed;
				inset: 0;
				z-index: 0;
				background-image:
					radial-gradient(1.5px 1.5px at 12% 16%, rgba(255, 255, 255, 0.9), transparent 60%),
					radial-gradient(1.5px 1.5px at 27% 40%, rgba(214, 247, 255, 0.8), transparent 60%),
					radial-gradient(1px 1px at 41% 11%, rgba(255, 255, 255, 0.75), transparent 60%),
					radial-gradient(1.5px 1.5px at 56% 26%, rgba(255, 255, 255, 0.85), transparent 60%),
					radial-gradient(1px 1px at 67% 14%, rgba(214, 247, 255, 0.7), transparent 60%),
					radial-gradient(1.5px 1.5px at 81% 34%, rgba(255, 255, 255, 0.8), transparent 60%),
					radial-gradient(1px 1px at 91% 20%, rgba(255, 255, 255, 0.7), transparent 60%),
					radial-gradient(1px 1px at 19% 58%, rgba(255, 255, 255, 0.58), transparent 60%),
					radial-gradient(1px 1px at 48% 52%, rgba(255, 255, 255, 0.5), transparent 60%),
					radial-gradient(1.5px 1.5px at 73% 60%, rgba(255, 255, 255, 0.6), transparent 60%),
					radial-gradient(1px 1px at 34% 70%, rgba(255, 255, 255, 0.42), transparent 60%),
					radial-gradient(1px 1px at 88% 64%, rgba(255, 255, 255, 0.4), transparent 60%),
					radial-gradient(1px 1px at 6% 36%, rgba(255, 255, 255, 0.55), transparent 60%),
					radial-gradient(1px 1px at 62% 6%, rgba(255, 255, 255, 0.65), transparent 60%);
				content: "";
				mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.95), rgba(0, 0, 0, 0.45) 55%, transparent 88%);
				-webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.95), rgba(0, 0, 0, 0.45) 55%, transparent 88%);
				opacity: 0.85;
				pointer-events: none;
				animation: twinkle 7s ease-in-out infinite alternate;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			a:focus-visible {
				outline: 3px solid var(--cyan);
				outline-offset: 4px;
			}

			/* no bar: nav floats on the sky. Children stay clickable, the strip itself doesn't block the hero. */
			.site-nav {
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				z-index: 10;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1.7rem max(1.25rem, calc((100vw - var(--page)) / 2)) 1rem;
				pointer-events: none;
			}

			.site-nav a,
			.site-nav nav {
				pointer-events: auto;
			}

			.site-name {
				display: inline-flex;
				align-items: center;
				gap: 0.7rem;
				color: var(--ink);
				font-family: "Fraunces", Georgia, serif;
				font-size: 1.05rem;
				font-weight: 800;
				letter-spacing: -0.01em;
				/* dark halo keeps the text legible against bright aurora */
				text-shadow: 0 1px 16px rgba(3, 9, 16, 0.95), 0 0 30px rgba(3, 9, 16, 0.7);
			}

			.site-mark {
				width: 2.1rem;
				height: 2.1rem;
				border: 1px solid var(--line-strong);
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.08);
				box-shadow: 0 0 26px rgba(97, 242, 255, 0.32), inset 0 0 12px rgba(112, 255, 158, 0.2);
				object-fit: cover;
			}

			.nav-links {
				display: flex;
				gap: 1.5rem;
				color: var(--ink-muted);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.84rem;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				text-shadow: 0 1px 16px rgba(3, 9, 16, 0.95), 0 0 30px rgba(3, 9, 16, 0.7);
			}

			.nav-links a {
				position: relative;
				transition: color 180ms ease, text-shadow 180ms ease;
			}

			.nav-links a[aria-current="page"] {
				color: var(--green);
			}

			.nav-links a:hover,
			.nav-links a:focus-visible {
				color: var(--green);
				text-shadow: 0 0 18px rgba(112, 255, 158, 0.55), 0 1px 16px rgba(3, 9, 16, 0.9);
			}

			main {
				position: relative;
				z-index: 1;
				width: 100%;
				margin: 0 auto;
			}

			.page-section {
				position: relative;
				isolation: isolate;
				width: min(var(--page), calc(100% - 2rem));
				margin: 0 auto;
				padding: 7rem 0;
			}

			.page-section::before {
				position: absolute;
				inset: 1rem -8vw auto;
				z-index: -1;
				height: 30rem;
				/* soft radial blooms, no hard edges */
				background:
					radial-gradient(50% 70% at 24% 28%, rgba(112, 255, 158, 0.13), transparent 70%),
					radial-gradient(52% 72% at 68% 36%, rgba(84, 137, 255, 0.12), transparent 72%);
				content: "";
				filter: blur(48px);
				opacity: 0.9;
				pointer-events: none;
			}

			.hero {
				position: relative;
				isolation: isolate;
				display: grid;
				align-content: center;
				width: min(var(--page), calc(100% - 2rem));
				min-height: calc(100vh - 68px);
				margin: 0 auto;
				padding: 7rem 0 9rem;
			}

			.hero::before {
				position: absolute;
				inset: -4rem -12vw auto -6vw;
				z-index: -1;
				height: 34rem;
				/* organic aurora bloom that fades to nothing, no rectangle */
				background:
					radial-gradient(58% 80% at 72% 32%, rgba(112, 255, 158, 0.22), transparent 70%),
					radial-gradient(56% 76% at 48% 28%, rgba(97, 242, 255, 0.17), transparent 72%),
					radial-gradient(52% 72% at 28% 44%, rgba(181, 114, 255, 0.18), transparent 72%);
				content: "";
				filter: blur(52px);
				opacity: 0.85;
				pointer-events: none;
			}

			.hero-content {
				position: relative;
				max-width: 800px;
				animation: reveal-up 720ms ease-out both;
			}

			.kicker,
			.project-label {
				margin: 0 0 1rem;
				color: var(--green);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.8rem;
				font-weight: 600;
				letter-spacing: 0;
				text-transform: uppercase;
			}

			.hero h1,
			.page-title {
				margin: 0;
				color: var(--ink);
				font-family: "Fraunces", Georgia, serif;
				font-size: 6rem;
				font-weight: 900;
				letter-spacing: -0.025em;
				line-height: 0.92;
				text-wrap: balance;
				/* faint aurora glow lifting the name off the night sky */
				text-shadow: 0 0 48px rgba(97, 242, 255, 0.18), 0 0 90px rgba(112, 255, 158, 0.12);
			}

			.blurb {
				max-width: 620px;
				margin: 1.5rem 0 0;
				color: var(--ink-muted);
				font-size: 1.35rem;
				line-height: 1.55;
			}

			.section-heading {
				margin: 0 0 1.5rem;
				color: var(--ink);
				font-family: "Fraunces", Georgia, serif;
				font-size: 3.8rem;
				font-weight: 900;
				letter-spacing: -0.02em;
				line-height: 1;
			}

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.1rem;
			}

			.project-card {
				position: relative;
				display: grid;
				min-height: 19rem;
				border: 1px solid var(--line);
				border-radius: 16px;
				/* dark aurora glass */
				background: linear-gradient(158deg, rgba(20, 35, 48, 0.72), rgba(8, 15, 25, 0.66));
				backdrop-filter: blur(14px);
				box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
				color: var(--ink);
				padding: 1.7rem 1.7rem 1.6rem 2.1rem;
				overflow: hidden;
				transition:
					transform 200ms ease,
					box-shadow 200ms ease,
					border-color 200ms ease;
				animation: reveal-up 700ms ease-out both;
				animation-delay: calc(var(--card-index, 0) * 85ms);
			}

			.project-card:hover,
			.project-card:focus-within {
				border-color: rgba(112, 255, 158, 0.5);
				box-shadow: 0 34px 96px rgba(0, 0, 0, 0.55), 0 0 44px rgba(112, 255, 158, 0.12);
				transform: translateY(-5px);
			}

			/* aurora accent on the left edge */
			.project-card::before {
				position: absolute;
				inset: 1.4rem auto 1.4rem 1rem;
				width: 3px;
				border-radius: 3px;
				background: linear-gradient(var(--green), var(--cyan), var(--violet));
				content: "";
				opacity: 0.9;
			}

			/* aurora glow in the corner, brightens on hover */
			.project-card::after {
				position: absolute;
				inset: -45% -35% auto auto;
				z-index: 0;
				width: 75%;
				height: 75%;
				background: radial-gradient(circle, rgba(97, 242, 255, 0.16), transparent 65%);
				content: "";
				opacity: 0.45;
				pointer-events: none;
				transition: opacity 200ms ease;
			}

			.project-card:hover::after,
			.project-card:focus-within::after {
				opacity: 1;
			}

			.project-card > * {
				position: relative;
				z-index: 1;
			}

			.project-card-header {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1rem;
			}

			.project-card-link {
				display: block;
				color: var(--ink);
			}

			.project-card-link:hover,
			.project-card-link:focus-visible,
			.link-row a:hover,
			.link-row a:focus-visible,
			.back-link:hover,
			.back-link:focus-visible {
				text-decoration: underline;
				text-underline-offset: 0.3em;
			}

			.project-card h3 {
				margin: 0;
				font-family: "Fraunces", Georgia, serif;
				font-size: 1.75rem;
				font-weight: 800;
				letter-spacing: -0.01em;
				line-height: 1.08;
			}

			.project-card p {
				margin: 1.1rem 0 0;
				color: var(--ink-muted);
				font-size: 1rem;
				line-height: 1.62;
			}

			.project-number {
				color: var(--ink-soft);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.82rem;
				font-weight: 600;
			}

			.project-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				list-style: none;
				margin: 1.3rem 0 0;
				padding: 0;
			}

			.project-tags li {
				border: 1px solid rgba(112, 255, 158, 0.24);
				border-radius: 999px;
				background: rgba(112, 255, 158, 0.05);
				color: var(--ink-muted);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.72rem;
				letter-spacing: 0.02em;
				line-height: 1;
				padding: 0.4rem 0.72rem;
				white-space: nowrap;
			}

			.detail-tags {
				margin-top: 2rem;
			}

			.link-row {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				margin-top: 1.5rem;
			}

			.link-row a,
			.back-link {
				color: var(--green);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.9rem;
				font-weight: 700;
			}

			.back-link {
				display: inline-block;
				margin-bottom: 2rem;
			}

			.prose {
				max-width: 760px;
				margin-top: 2rem;
			}

			.prose p {
				margin: 0 0 1.25rem;
				color: var(--ink-muted);
				font-size: 1.08rem;
				line-height: 1.65;
			}

			.project-detail {
				min-height: calc(100vh - 58px);
			}

			.detail-header {
				max-width: 860px;
			}

			.detail-body {
				display: grid;
				grid-template-columns: minmax(0, 760px) minmax(12rem, 1fr);
				gap: 3rem;
				align-items: start;
				margin-top: 2.8rem;
			}

			.detail-aside {
				position: sticky;
				top: 7rem;
				border-left: 1px solid var(--line);
				padding-left: 1.25rem;
			}

			.detail-aside p {
				margin: 0 0 0.75rem;
				color: var(--ink-soft);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.82rem;
				line-height: 1.5;
				text-transform: uppercase;
			}

			.project-embed {
				width: 100%;
				min-height: 420px;
				margin-top: 2rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: rgba(255, 255, 255, 0.06);
			}

			.text-page {
				min-height: calc(100vh - 58px);
			}

			.about-layout {
				display: grid;
				grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1.2fr);
				gap: 3rem;
				align-items: start;
				margin-top: 2.6rem;
			}

			.about-photo {
				position: relative;
				margin: 0;
				animation: reveal-up 740ms ease-out both;
			}

			.about-photo::before {
				position: absolute;
				inset: -1px;
				z-index: -1;
				border-radius: var(--radius);
				background: linear-gradient(135deg, var(--green), var(--cyan), var(--red), var(--violet));
				content: "";
				filter: blur(18px);
				opacity: 0.42;
			}

			.about-photo img {
				display: block;
				width: 100%;
				aspect-ratio: 4 / 5;
				border: 1px solid var(--line-strong);
				border-radius: var(--radius);
				box-shadow: var(--shadow);
				object-fit: cover;
				object-position: 50% 38%;
			}

			.about-photo figcaption {
				margin-top: 0.7rem;
				color: var(--ink-soft);
				font-family: "IBM Plex Mono", monospace;
				font-size: 0.8rem;
			}

			@keyframes aurora-drift {
				from {
					background-position: 0% 0%, 100% 0%;
					transform: skewX(-8deg) translate3d(-2vw, 0, 0);
				}

				to {
					background-position: 32% 0%, 68% 0%;
					transform: skewX(-4deg) translate3d(3vw, 1.5vh, 0);
				}
			}

			@keyframes twinkle {
				from {
					opacity: 0.58;
				}

				to {
					opacity: 0.95;
				}
			}

			@keyframes reveal-up {
				from {
					opacity: 0;
					transform: translateY(18px);
				}

				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@media (max-width: 920px) {
				.hero h1,
				.page-title {
					font-size: 4.2rem;
				}

				.section-heading {
					font-size: 2.9rem;
				}

				.about-layout,
				.detail-body {
					grid-template-columns: 1fr;
				}

				.detail-aside {
					position: static;
					border-left: 0;
					border-top: 1px solid var(--line);
					padding: 1.25rem 0 0;
				}
			}

			@media (max-width: 700px) {
				.site-nav {
					align-items: center;
					padding: 0.8rem 1rem;
				}

				.site-name span {
					display: none;
				}

				.nav-links {
					gap: 0.85rem;
					font-size: 0.75rem;
				}

				.hero {
					min-height: calc(100vh - 58px);
					padding: 5rem 0 6rem;
				}

				.hero h1,
				.page-title {
					font-size: 3.1rem;
					line-height: 1;
				}

				.blurb {
					font-size: 1.08rem;
				}

				.section-heading {
					font-size: 2.4rem;
				}

				.page-section {
					padding: 5rem 0;
				}

				.projects-grid {
					grid-template-columns: 1fr;
				}

				.project-card {
					min-height: 18rem;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				*,
				*::before,
				*::after {
					animation-duration: 1ms !important;
					animation-iteration-count: 1 !important;
					scroll-behavior: auto !important;
					transition-duration: 1ms !important;
				}
			}
		</style>
	</head>
	<body>
		<header class="site-nav">
			<a class="site-name" href={hrefWithBase("/")}>
				<img class="site-mark" src={penguinImage} alt="" />
				<span>Ronnie Wang</span>
			</a>
			<nav class="nav-links" aria-label="Main navigation">
				<a
					href={hrefWithBase("/projects")}
					aria-current={currentPath.startsWith("/projects") ? "page" : undefined}
					>Projects</a
				>
				<a
